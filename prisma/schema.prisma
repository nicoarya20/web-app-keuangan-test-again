// ============================================================
// Personal Finance App — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// User (root entity — all data belongs to a user)
// ============================================================
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  incomes         Income[]
  expenses        Expense[]
  wishlists       Wishlist[]
  savings         Saving[]
  wallets         Wallet[]
  budgets         Budget[]

  @@map("users")
}

// ============================================================
// Income
// ============================================================
model Income {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount    Int                        // stored in smallest currency unit (e.g. Rupiah)
  category  String
  date      DateTime                   // stored as date-only (time stripped at app level)
  recurring Boolean  @default(false)
  note      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, category])
  @@map("incomes")
}

// ============================================================
// Expense
// ============================================================
model Expense {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount    Int
  category  String
  date      DateTime
  note      String?
  tags      String[] // PostgreSQL array of text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, category])
  @@map("expenses")
}

// ============================================================
// Wishlist (savings goals / items the user wants to buy)
// ============================================================
model Wishlist {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  targetPrice     Int
  currentProgress Int      @default(0)
  priority        Priority @default(MEDIUM)   // low | medium | high
  note            String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@map("wishlists")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

// ============================================================
// Saving (one-off saving or investment entry)
// ============================================================
model Saving {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount    Int
  goalName  String
  date      DateTime
  type      SavingType                    // saving | investment

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, date])
  @@index([userId, type])
  @@map("savings")
}

enum SavingType {
  SAVING
  INVESTMENT
}

// ============================================================
// Wallet (physical cash, e-wallet, bank account)
// ============================================================
model Wallet {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  walletType      WalletType                              // cash | ewallet | bank
  initialBalance  Int
  currentBalance  Int                @default(0)          // computed from transactions

  transactions    WalletTransaction[]

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([userId])
  @@index([userId, walletType])
  @@map("wallets")
}

enum WalletType {
  CASH
  EWALLET
  BANK
}

// ============================================================
// WalletTransaction (top-up or expense for a specific wallet)
// ============================================================
model WalletTransaction {
  id        String         @id @default(cuid())
  walletId  String
  wallet    Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type      WalletTxType                  // topup | expense
  amount    Int
  note      String?
  date      DateTime

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([walletId, date])
  @@index([walletId, type])
  @@map("wallet_transactions")
}

enum WalletTxType {
  TOPUP
  EXPENSE
}

// ============================================================
// Budget (monthly budget per category)
// ============================================================
model Budget {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  category  String                      // e.g. "Food & Dining"
  amount    Int                         // monthly budget limit

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category])
  @@index([userId])
  @@map("budgets")
}
